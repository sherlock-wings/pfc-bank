# Committed, non-secret defaults for the Evidence dashboard.
# Secrets and local overrides go in .env.local (git-ignored), which wins over
# this file.
#
# data_root is the S3 prefix the dashboard reads dashboard_mart parquet from.
# Referenced in sources/pfc_bank/*.sql as ${data_root} (Evidence exposes any
# EVIDENCE_VAR__<name> as ${<name>} inside source queries).
#
# Default = the real pipeline's prefix, so `npm run sources && npm run dev`
# works out of the box. Persona/demo mode overrides it by writing .env.local
# with e.g. EVIDENCE_VAR__data_root=s3://pfc-nfcu/demo/jordan-rivera
EVIDENCE_VAR__data_root=s3://pfc-nfcu

# Dashboard display labels (surfaced by sources/pfc_bank/persona.sql):
#   family_name  -> the "<name> Family Finances :)" page title
#   home_address -> the Housing card's "Mortgage on <address>" label
# These are committed defaults, so they are deliberately generic PLACEHOLDERS,
# never a real name/address (this file ships in a public repo). The real values
# live only in git-ignored places that override this file via .env.local:
#   - locally:  dashboard/.env.real  (rfr.sh copies it to .env.local)
#   - in CI:    GitHub `dev` env vars DASHBOARD_FAMILY_NAME / DASHBOARD_HOME_ADDRESS
#               (deploy_dashboard.yml writes them into .env.local before build)
# persona.sh overrides them per-run in .env.local with the persona's identity.
EVIDENCE_VAR__family_name=Sample
EVIDENCE_VAR__home_address=123 Example St
