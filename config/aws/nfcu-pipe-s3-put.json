  {
      "Version": "2012-10-17",
      "Statement": [
          {
              "Sid": "BucketLevelActions",
              "Effect": "Allow",
              "Action": [
                  "s3:ListBucket",
                  "s3:ListBucketVersions"
              ],
              "Resource": [
                  "arn:aws:s3:::pfc-nfcu",
                  "arn:aws:s3:::pfc-nfcu/"
              ]
          },
          {
              "Sid": "ObjectLevelActions",
              "Effect": "Allow",
              "Action": [
                  "s3:GetObject",
                  "s3:PutObject",
                  "s3:DeleteObject",
                  "s3:GetObjectVersion"
              ],
              "Resource": "arn:aws:s3:::pfc-nfcu/*"
          }
      ]
  }